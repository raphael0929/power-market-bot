# ── 기존: 전력시장 봇 ──────────────────────────────
KPX_SERVICE_KEY=여기에_공공데이터_API키_입력
X_API_KEY=여기에_X_API_Key
X_API_SECRET=여기에_X_API_Key_Secret
X_ACCESS_TOKEN=여기에_Access_Token
X_ACCESS_SECRET=여기에_Access_Token_Secret

# ── 신규: 블로그·YouTube 에이전트 ─────────────────
# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Google Blogger API v3 (setup_auth.py 실행 후 복사)
BLOGGER_OAUTH2_TOKEN={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
BLOGGER_BLOG_ID=숫자로_된_블로그ID

# YouTube Data API v3 (setup_auth.py 실행 후 복사)
YOUTUBE_OAUTH2_TOKEN={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
